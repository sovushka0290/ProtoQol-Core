# ── AI Council (Gemini 2.0 Flash) ──
# Single key or comma-separated pool for round-robin rotation
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
# GEMINI_API_KEYS=key1,key2,key3  # Optional: pool for rate-limit resilience

# ── Telegram Bot ──
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
ADMIN_ID=YOUR_TELEGRAM_USER_ID

# ── Solana Blockchain ──
RPC_URL=https://api.devnet.solana.com
MASTER_AUTHORITY_SECRET=protoqol_master_engine_authority_2026
WALLET_SALT=protoqol_nomad_user_salt_2026

# ── Frontend ──
WEBAPP_URL=https://your-mini-app-url.vercel.app/
PROTOQOL_ENGINE_URL=http://localhost:8000
